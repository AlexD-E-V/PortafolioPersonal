# Web3Forms — clave de acceso del formulario de contacto.
# Obtenla gratis en https://web3forms.com poniendo el email donde
# quieres recibir los mensajes. Copia este archivo a .env y pega tu clave.
# El prefijo PUBLIC_ es obligatorio para que Astro la exponga al cliente.
PUBLIC_WEB3FORMS_KEY=tu-access-key-aqui
